# Paste this into the existing Caddyfile on the Hetzner VM and replace
# api.padelcompanion.example.com with the real API hostname.

api.padelcompanion.example.com {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    reverse_proxy padel_companion_api:8787 {
        health_uri /api/health
        health_interval 30s
        health_timeout 5s
    }

    log {
        output file /var/log/caddy/padel_companion_api.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
