{
	"name": "padelcompanion",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:full": "node --import tsx/esm backend/src/index.ts & vite dev",
		"build": "vite build",
		"deploy": "npm run build && gh-pages -d build -b gh-pages -t --nojekyll --cname padelcompanion.se -r https://github.com/monswiklund/padelcompanion-site.git -m \"Deploy site\"",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "vitest",
		"test:e2e": "playwright test",
		"api": "node --import tsx/esm backend/src/index.ts",
		"api:migrate": "node --import tsx/esm backend/migrate.ts",
		"api:test": "vitest --config backend/vitest.config.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"gh-pages": "^6.3.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.19.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"lenis": "^1.3.23",
		"motion": "^12.39.0",
		"pg": "^8.20.0",
		"tailwind-merge": "^3.6.0"
	},
	"overrides": {
		"cookie": "^0.7.2"
	}
}
